{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,

    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "noEmit": true,
    "isolatedModules": true,

    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,

    "skipLibCheck": true,
    "strict": true,

    "baseUrl": ".",

    "paths": {
      "@/*": ["src/*"],

      "@core/*": ["src/core/*"],

      "@db": ["src/core/database/index.ts"],
      "@db/*": ["src/core/database/*"],

      "@modules/*": ["src/modules/*"],

      "@utils/*": ["src/core/utils/*"]
    },

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"]
}